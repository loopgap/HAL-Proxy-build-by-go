# Set default behavior to automatically normalize line endings
* text=auto

# Explicitly declare text files
*.go text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.sql text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf

# Declare files that will always have CRLF line endings on checkout
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# Dockerfile should use LF
Dockerfile text eol=lf
Dockerfile.* text eol=lf

# Scripts
*.sh text eol=lf

# Ignore all node_modules
node_modules/** -text
