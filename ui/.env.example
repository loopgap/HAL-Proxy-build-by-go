# BridgeOS UI Environment Variables
# Copy this file to .env.local and configure for your environment

# API Base URL
# - Development: leave empty to use Vite dev proxy (/v1 -> http://localhost:8080)
# - Production: set to your API server URL (e.g., https://api.example.com/v1)
# - Preview: leave empty or set to /v1 for same-origin
VITE_API_BASE_URL=

# Example production configuration:
# VITE_API_BASE_URL=https://api.example.com/v1
